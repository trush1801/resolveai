cat << 'EOF' > .gitignore
# System Files
.DS_Store
Thumbs.db

# Dependencies
node_modules/
jspm_packages/
web_modules/
.npm/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python Virtual Environments & Caches
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Databases & Local Volumetric Storage
pgdata/
mongodata/
qdrantdata/
*.db
*.sqlite

# Environment Variables & Secrets (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# IDEs & Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
EOF